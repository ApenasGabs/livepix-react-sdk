{
  "name": "livepix-react-sdk",
  "version": "1.0.0",
  "description": "A React SDK for interacting with the LivePix API.",
  "main": "dist/livepix-react-sdk.cjs.js",
  "module": "dist/livepix-react-sdk.esm.js",
  "umd:main": "dist/livepix-react-sdk.umd.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "rollup -c -w",
    "build": "rollup -c rollup.config.cjs",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx src",
    "preview": "vite preview",
    "test": "jest",
    "prepare": "yarn run build",
    "example": "cd example && yarn run dev",
    "test:ci": "jest --coverage",
    "ci:test": "yarn lint && yarn test:ci",
    "ci:build": "yarn build && cd example && yarn build"
  },
  "keywords": [
    "react",
    "sdk",
    "livepix",
    "api"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.3.1",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "buffer": "^6.0.3",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "rollup": "^2.79.1",
    "rollup-plugin-terser": "^7.0.2",
    "stream-browserify": "^3.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0",
    "util": "^0.12.5"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  }
}
